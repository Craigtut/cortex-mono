{
  "name": "cortex-mono",
  "private": true,
  "author": "Craigtut",
  "description": "Cortex: production-grade agent infrastructure",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "tsc --build --watch packages/cortex packages/cortex-code",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint packages/*/src packages/*/tests",
    "lint:fix": "eslint packages/*/src packages/*/tests --fix",
    "clean": "rm -rf packages/*/dist node_modules/.cache"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@10.0.0",
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^2.1.0"
  }
}
