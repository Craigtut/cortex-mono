{
  "name": "@animus-labs/cortex",
  "version": "0.1.0",
  "license": "MIT",
  "author": "Craigtut",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:eval": "vitest run --config vitest.config.eval.ts",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.58.0",
    "@mariozechner/pi-ai": "^0.58.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sinclair/typebox": "^0.34.0",
    "@vscode/ripgrep": "^1.17.1",
    "zod-to-json-schema": "^3.25.1"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zod": "^4.0.0"
  }
}
