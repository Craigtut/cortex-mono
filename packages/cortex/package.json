{
  "name": "@animus-labs/cortex",
  "version": "0.1.0",
  "description": "Production-grade agent framework with structured context management, compaction, tools, and MCP support",
  "license": "MIT",
  "author": "Animus Labs",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/Animus-Labs/cortex-mono.git",
    "directory": "packages/cortex"
  },
  "bugs": {
    "url": "https://github.com/Animus-Labs/cortex-mono/issues"
  },
  "homepage": "https://github.com/Animus-Labs/cortex-mono/tree/main/packages/cortex",
  "keywords": [
    "ai",
    "agent",
    "llm",
    "context-management",
    "compaction",
    "mcp",
    "tools",
    "anthropic",
    "openai"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:eval": "vitest run --config vitest.config.eval.ts",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.58.0",
    "@mariozechner/pi-ai": "^0.58.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sinclair/typebox": "^0.34.0",
    "@vscode/ripgrep": "^1.17.1",
    "turndown": "^7.2.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zod": "^4.0.0"
  }
}
