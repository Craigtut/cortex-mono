{
  "name": "@animus-labs/cortex-code",
  "version": "0.1.0",
  "license": "MIT",
  "author": "Craigtut",
  "description": "A terminal-based coding agent built on the Cortex agent framework",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cortex": "./dist/index.js"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@animus-labs/cortex": "*",
    "@mariozechner/pi-tui": "^0.65.0",
    "chalk": "^5.4.0",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
