{
  "name": "@animus-labs/cortex-code",
  "version": "0.1.0",
  "license": "MIT",
  "author": "Animus Labs",
  "description": "Terminal-based coding agent built on the Cortex agent framework",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/Animus-Labs/cortex-mono.git",
    "directory": "packages/cortex-code"
  },
  "bugs": {
    "url": "https://github.com/Animus-Labs/cortex-mono/issues"
  },
  "homepage": "https://github.com/Animus-Labs/cortex-mono/tree/main/packages/cortex-code",
  "keywords": [
    "ai",
    "agent",
    "coding-agent",
    "cli",
    "terminal",
    "llm",
    "cortex"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cortex": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@animus-labs/cortex": "^0.1.0",
    "@mariozechner/pi-tui": "^0.65.0",
    "chalk": "^5.4.0",
    "cli-highlight": "^2.1.11",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
